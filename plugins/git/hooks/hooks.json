{
	"description": "Warn about uncommitted changes when Claude Code stops",
	"hooks": {
		"Stop": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "if [ -n \"${CLAUDE_PLUGIN_ROOT:-}\" ]; then \"${CLAUDE_PLUGIN_ROOT}/scripts/check-dirty-tree.sh\"; fi",
						"timeout": 5
					}
				]
			}
		]
	}
}
