#!/usr/bin/env bash
# Rebase current branch onto upstream/main
# Usage: rebase
#
# Environment variables:
#   UPSTREAM_REMOTE - Remote to rebase onto (default: upstream)
#   UPSTREAM_BRANCH - Branch to rebase onto (default: main)
#   OFFLINE         - Skip fetching if true (default: false)

set -Eeuo pipefail

upstream_remote="${UPSTREAM_REMOTE:-upstream}"
upstream_branch="${UPSTREAM_BRANCH:-main}"

if [ "$#" -ne 0 ]; then
    echo "Usage: rebase" >&2
    exit 2
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Check for local modifications
"$SCRIPT_DIR/check-local-modifications"

# Fetch upstream
"$SCRIPT_DIR/fetch"

echo "Running: git rebase --autosquash --rebase-merges --update-refs ${upstream_remote}/${upstream_branch}"
git rebase --autosquash --rebase-merges --update-refs "${upstream_remote}/${upstream_branch}"
